--------------------------------------------------
-- CREATE SLOT
--------------------------------------------------
function MozCraft:createSlot(data)
	if not pages[data.Tab] then
		self:createTab(data.Tab)
	end

	local function buildSlot(parent)
		local slot = Instance.new("TextButton")
		slot.Size = UDim2.new(0,90,0,90)
		slot.BackgroundColor3 = Color3.fromRGB(35,35,35)
		slot.Text = ""
		slot.Name = data.Name
		slot.Parent = parent
		Instance.new("UICorner",slot).CornerRadius = UDim.new(0,8)

		slot.MouseEnter:Connect(function()
			slot.BackgroundColor3 = Color3.fromRGB(55,55,55)
		end)
		slot.MouseLeave:Connect(function()
			slot.BackgroundColor3 = Color3.fromRGB(35,35,35)
		end)

		local icon = Instance.new("ImageLabel")
		icon.Size = UDim2.new(0,60,0,60)
		icon.Position = UDim2.new(0.5,-30,0,5)
		icon.BackgroundTransparency = 1
		icon.Image = "rbxassetid://"..data.Icon
		icon.Parent = slot

		local text = Instance.new("TextLabel")
		text.Size = UDim2.new(1,0,0,20)
		text.Position = UDim2.new(0,0,1,-20)
		text.BackgroundTransparency = 1
		text.Text = data.Name
		text.TextColor3 = Color3.new(1,1,1)
		text.Font = Enum.Font.Gotham
		text.TextSize = 14
		text.Parent = slot

		local star = Instance.new("TextButton")
		star.Text = "☆"
		star.Size = UDim2.new(0,18,0,18)
		star.Position = UDim2.new(1,-20,0,2)
		star.BackgroundTransparency = 1
		star.TextColor3 = Color3.fromRGB(255,215,0)
		star.Parent = slot

		slot.MouseButton1Click:Connect(function()
			clickSound:Play()
			pcall(function()
				loadstring(game:HttpGet(data.Script))()
			end)
		end)

		star.MouseButton1Click:Connect(function()
			clickSound:Play()
			if favorites[data.Name] then
				favorites[data.Name]=nil
				star.Text="☆"
				for _,v in pairs(pages["Favorites"]:GetChildren()) do
					if v.Name==data.Name then v:Destroy() end
				end
			else
				favorites[data.Name]=true
				star.Text="★"
				local clone = slot:Clone()
				clone.Parent = pages["Favorites"]
			end
		end)

		return slot
	end

	-- Add slot to main tab
	local slot = buildSlot(pages[data.Tab])
	-- Add slot to All tab
	buildSlot(pages["All"])
end

--------------------------------------------------
-- SEARCH FUNCTIONALITY
--------------------------------------------------
search:GetPropertyChangedSignal("Text"):Connect(function()
	typingSound:Play()
	local txt = string.lower(search.Text)
	for _,page in pairs(pages) do
		for _,slot in pairs(page:GetChildren()) do
			if slot:IsA("TextButton") then
				slot.Visible = string.find(string.lower(slot.Name), txt) ~= nil
			end
		end
	end
end)

